# Helm Gateway 환경변수
# cp .env.example .env 후 실제 값 입력

# ============================
# 서버
# ============================
HOST=0.0.0.0
PORT=8080
RUST_LOG=qkvg_gateway=info,actix_web=warn

# ============================
# 보안
# ============================
JWT_SECRET=change-this-to-random-32char-secret-in-production

# ============================
# 데이터베이스 (PostgreSQL)
# ============================
DATABASE_URL=postgres://qkvg:password@localhost:5432/qkvg_gateway

# ============================
# A전선: LLM API
# ============================
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ============================
# B전선: Search
# ============================
BRAVE_API_KEY=BSA...

# ============================
# C전선: DeFi
# ============================
BASE_RPC_URL=https://mainnet.base.org
ESCROW_CONTRACT_ADDRESS=0x...
GATEWAY_PRIVATE_KEY=0x...  # 정산용 (절대 외부 노출 금지)

# ============================
# 결제
# ============================
TREASURY_ADDRESS=0x...
BNKR_USD_RATE=0.50

# ============================
# Redis (Nonce/캐시)
# ============================
REDIS_URL=redis://localhost:6379

# ============================
# 개발 전용
# ============================
DEV_MODE=true    # true 시 DB 없이 더미 응답

# C-Front DeFi 오라클
COINGECKO_API_KEY=your_coingecko_pro_key  # 무료 tier도 작동 (rate limit 있음)
# Pyth Network: 별도 키 불필요 (hermes.pyth.network 공개 API)

# A-Front LLM
OPENAI_API_KEY=sk-...         # GPT-4o 라우팅용
ANTHROPIC_API_KEY=sk-ant-...  # Claude 라우팅용 (기본)

# B-Front Search
BRAVE_API_KEY=BSA...          # Brave Search API
