# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HELM-SENSE GATEWAY v0.2.0 PRODUCTION CONFIG (GANDIVA-QUIC EDITION)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── NETWORK & PORT ───────────────────────────────────────────────────
HOST=0.0.0.0
RUNTIME_PORT=8080
RUNTIME_EXTERNAL_PORT=443
QUIC_PORT=4433

# ── DISTRIBUTED SCALE (WORKER NODES) ─────────────────────────────────
# [IMPORTANT] 증설된 GCP 서버(Helm Core)들의 gRPC IP를 쉼표(,)로 구분하여 입력
# 예: http://10.x.x.1:50051,http://10.x.x.2:50051
WORKER_NODES=http://helm-core:50051

# ── MEMORY OFFLOAD (REDIS) ───────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── DATABASE (POSTGRES) ──────────────────────────────────────────────
DATABASE_URL=postgres://helm_user:helm_secret@db:5432/helm

# ── SECURITY (SECRECY CRATE) ─────────────────────────────────────────
JWT_SECRET=PROD_SECRET_REPLACE_ME_VIA_VAULT
ANTHROPIC_API_KEY=PLACEHOLDER_KEY
OPENAI_API_KEY=PLACEHOLDER_KEY
BRAVE_API_KEY=PLACEHOLDER_KEY
BASE_RPC_URL=https://mainnet.base.org

# ── PERFORMANCE LIMITS ───────────────────────────────────────────────
# OOM 및 스레드 고갈 방지 (Kaleidoscope Heuristics)
PROXY_TIMEOUT=120
REGISTRY_CACHE_MAX_KEYS=100000
REGISTRY_CACHE_STD_TTL=600

# ── G-METRIC CONFIG ──────────────────────────────────────────────────
USE_SEMANTIC_EMBED=true
MIN_G_SCORE_THRESHOLD=0.5
